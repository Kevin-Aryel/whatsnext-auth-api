<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Unit Tests" verbose="1" parallel="false">

    <test name="Service Tests">
        <classes>
            <class name="com.whatsnext.authapi.unit.service.JwtServiceTest"/>
            <class name="com.whatsnext.authapi.unit.service.PasswordValidatorTest"/>
            <class name="com.whatsnext.authapi.unit.service.AuthServiceTest"/>
            <class name="com.whatsnext.authapi.unit.service.TokenBlacklistServiceTest"/>
            <class name="com.whatsnext.authapi.unit.service.TokenCleanupServiceTest"/>
        </classes>
    </test>

    <test name="Controller Tests">
        <classes>
            <class name="com.whatsnext.authapi.unit.controller.AuthControllerTest"/>
            <class name="com.whatsnext.authapi.unit.controller.UserControllerTest"/>
        </classes>
    </test>

    <test name="Filter Tests">
        <classes>
            <class name="com.whatsnext.authapi.unit.filter.RateLimitFilterTest"/>
            <class name="com.whatsnext.authapi.unit.filter.JwtAuthenticationFilterTest"/>
        </classes>
    </test>

    <test name="Exception Handler Tests">
        <classes>
            <class name="com.whatsnext.authapi.unit.exception.GlobalExceptionHandlerTest"/>
        </classes>
    </test>

    <test name="Config Tests">
        <classes>
            <class name="com.whatsnext.authapi.unit.config.SecurityHeadersTest"/>
        </classes>
    </test>

</suite>
