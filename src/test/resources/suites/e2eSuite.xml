<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="E2E Tests" verbose="1" parallel="false">

    <test name="Auth E2E">
        <classes>
            <class name="com.whatsnext.authapi.e2e.auth.RegisterE2ETest"/>
            <class name="com.whatsnext.authapi.e2e.auth.LoginE2ETest"/>
            <class name="com.whatsnext.authapi.e2e.auth.RefreshE2ETest"/>
            <class name="com.whatsnext.authapi.e2e.auth.LogoutE2ETest"/>
        </classes>
    </test>

    <test name="User E2E">
        <classes>
            <class name="com.whatsnext.authapi.e2e.user.UserE2ETest"/>
        </classes>
    </test>

</suite>
