{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["errors"],
  "additionalProperties": false,
  "properties": {
    "errors": {
      "type": "array",
      "minItems": 1,
      "maxItems": 13,
      "items": {
        "type": "object",
        "required": ["code", "title", "detail"],
        "additionalProperties": false,
        "properties": {
          "code": {
            "type": "string",
            "maxLength": 255
          },
          "title": {
            "type": "string",
            "maxLength": 255
          },
          "detail": {
            "type": "string",
            "maxLength": 2048
          }
        }
      }
    },
    "meta": {
      "type": "object",
      "required": ["requestDateTime"],
      "additionalProperties": false,
      "properties": {
        "requestDateTime": {
          "type": "string",
          "format": "date-time",
          "maxLength": 20
        },
        "requestId": {
          "type": "string",
          "maxLength": 64
        }
      }
    }
  }
}